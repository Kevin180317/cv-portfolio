---
import React from "@/assets/icons/React.astro";
import AstroIcon from "@/assets/icons/Astroicon.astro";
import NextJS from "@/assets/icons/Next.astro";
import TypeScript from "@/assets/icons/TypeScript.astro";
import HTML from "@/assets/icons/Html.astro";
import CSS from "@/assets/icons/Css.astro";
import JavaScript from "@/assets/icons/Javascript.astro";
import Node from "@/assets/icons/Node.astro";
import Python from "@/assets/icons/Python.astro";
import MySQL from "@/assets/icons/Mysql.astro";
import Github from "@/assets/icons/Github.astro";
import Kotlin from "@/assets/icons/Kotlin.astro";
import Java from "@/assets/icons/Java.astro";
import Cpanel from "@/assets/icons/Cpanel.astro";
import Vue from "@/assets/icons/Vue.astro";
import Laravel from "@/assets/icons/Laravel.astro";
import Supa from "@/assets/icons/Supa.astro";
import JWT from "@/assets/icons/JWT.astro";
import Express from "@/assets/icons/Express.astro";
import Expo from "@/assets/icons/Expo.astro";
import Todoist from "@/assets/icons/Todoist.astro";
import Slack from "@/assets/icons/Slack.astro";
import Vite from "@/assets/icons/Vite.astro";
import Firebase from "@/assets/icons/Firebase.astro";
import Tailwind from "@/assets/icons/Tailwind.astro";
import Motion from "@/assets/icons/Motion.astro";
import Google from "@/assets/icons/Google.astro";
import Meta from "@/assets/icons/Meta.astro";
import Mongo from "@/assets/icons/Mongo.astro";
import Vercel from "@/assets/icons/Vercel.astro";
import Netlify from "@/assets/icons/Netlify.astro";
import Stripe from "@/assets/icons/Stripe.astro";

const { URL } = Astro.props;
const isEn = URL === "/en/";

function getYearsSince(y: number) { return new Date().getFullYear() - y; }
const expYears = getYearsSince(2021);

const experience = isEn ? [
  {
    title: "Front-end & Back-end Developer",
    company: "Ecommetrica",
    period: "Sep 2023 – Present",
    items: [
      "Web development with React, Vite, Next.js, Astro",
      "Back-end with Express, REST APIs, JWT, OAuth, MySQL",
      "UI design with Figma · task management with Todoist",
      "SEO via Google Analytics, Meta Pixel, Google Tag Manager",
    ],
  },
  {
    title: "Full Stack Developer",
    company: "Universidad Cenyca",
    period: "Oct 2022 – Jul 2023",
    items: [
      "Academic platform split into 3 modules: Students, Teachers, Admin",
      "Laravel PHP / Vue.js / Tailwind CSS / MySQL",
    ],
  },
  {
    title: "Mobile App Developer",
    company: "Prometheus · Freelancer",
    period: "",
    items: [
      "Palliative care app: patients schedule appointments with doctors (Doctoralia-like flow)",
      "Android Java + iOS Swift · Firebase + OneSignal push notifications",
    ],
  },
] : [
  {
    title: "Desarrollador Front-end & Back-end",
    company: "Ecommetrica",
    period: "Sep 2023 – Presente",
    items: [
      "Desarrollo web con React, Vite, Next.js, Astro",
      "Back-end con Express, APIs REST, JWT, OAuth, MySQL",
      "Diseño de interfaces con Figma · gestión de tareas con Todoist",
      "SEO con Google Analytics, Meta Pixel, Google Tag Manager",
    ],
  },
  {
    title: "Desarrollador Full Stack",
    company: "Universidad Cenyca",
    period: "Oct 2022 – Jul 2023",
    items: [
      "Plataforma académica dividida en 3 módulos: Alumnos, Docentes, Control Académico",
      "Laravel PHP / Vue.js / Tailwind CSS / MySQL",
    ],
  },
  {
    title: "Desarrollador de Apps Móviles",
    company: "Prometheus · Freelancer",
    period: "",
    items: [
      "App móvil para cuidados paliativos: agenda de citas con catálogo de médicos (flujo tipo Doctoralia)",
      "Android Java + iOS Swift · Firebase + OneSignal notificaciones push",
    ],
  },
];

const education = isEn ? [
  { title: "B.S. Intelligent Systems Technologies", institution: "UDCI", period: "2017–2021",
    desc: "Software & Hardware, Python, line follower, sprinter/juice bot 5–15 kg" }
] : [
  { title: "Lic. Tecnologías en Sistemas Inteligentes", institution: "UDCI", period: "2017–2021",
    desc: "Software y Hardware, Python, seguidor de línea, sprinter y juice bot 5–15 kg" }
];

const skillGroups = [
  {
    id: "frontend", label: "Frontend",
    skills: ["html","css","javascript","typescript","react","nextjs","astro","vue","tailwind","motion"],
  },
  {
    id: "backend", label: "Backend",
    skills: ["node","express","php","python","supabase","jwt","stripe"],
  },
  {
    id: "mobile", label: isEn ? "Mobile" : "Mobile",
    skills: ["java","kotlin","expo"],
  },
  {
    id: "databases", label: isEn ? "Databases" : "Bases de Datos",
    skills: ["mysql","firebase","supabase","mongo"],
  },
  {
    id: "tools", label: isEn ? "Tools" : "Herramientas",
    skills: ["git","cpanel","vite","todoist","slack","vercel","netlify","google","meta"],
  },
];
---

<!-- Experience -->
<section id="experience" class="border-t border-gray-100 pt-12 pb-12 reveal">
  <p class="text-xs font-medium text-orange-500 tracking-widest uppercase mb-4">
    {isEn ? "Work" : "Trabajo"}
  </p>
  <h2 class="text-2xl font-bold text-gray-900 mb-8">
    {isEn ? `Professional Experience (${expYears}+ years)` : `Experiencia Profesional (${expYears}+ años)`}
  </h2>

  <div class="space-y-6">
    {experience.map((exp, i) => (
      <div
        class="reveal pl-4 border-l-2 border-gray-100 hover:border-orange-400 transition-colors duration-300"
        style={`transition-delay: ${i * 100}ms`}
      >
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-2 gap-1">
          <div>
            <h3 class="font-semibold text-gray-900">{exp.title}</h3>
            <p class="text-sm text-orange-500 font-medium">{exp.company}</p>
          </div>
          {exp.period && (
            <span class="text-xs text-gray-400 bg-gray-50 px-2.5 py-1 rounded-full self-start whitespace-nowrap">
              {exp.period}
            </span>
          )}
        </div>
        <ul class="space-y-1.5 mt-3">
          {exp.items.map(item => (
            <li class="flex items-start gap-2 text-sm text-gray-500">
              <span class="w-1 h-1 rounded-full bg-orange-400 flex-shrink-0 mt-2"></span>
              {item}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>

<!-- Education -->
<section class="border-t border-gray-100 pt-12 pb-12 reveal">
  <p class="text-xs font-medium text-orange-500 tracking-widest uppercase mb-4">
    {isEn ? "Education" : "Educación"}
  </p>

  {education.map(edu => (
    <div class="pl-4 border-l-2 border-gray-100 hover:border-orange-400 transition-colors duration-300">
      <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-2 gap-1">
        <div>
          <h3 class="font-semibold text-gray-900">{edu.title}</h3>
          <p class="text-sm text-orange-500 font-medium">{edu.institution}</p>
        </div>
        <span class="text-xs text-gray-400 bg-gray-50 px-2.5 py-1 rounded-full self-start">
          {edu.period}
        </span>
      </div>
      <p class="text-sm text-gray-500 mt-2">{edu.desc}</p>
    </div>
  ))}
</section>

<!-- Skills -->
<section class="border-t border-gray-100 pt-12 pb-12 reveal">
  <p class="text-xs font-medium text-orange-500 tracking-widest uppercase mb-4">
    {isEn ? "Skills" : "Habilidades"}
  </p>
  <h2 class="text-2xl font-bold text-gray-900 mb-8">
    {isEn ? "Tech Stack" : "Stack Tecnológico"}
  </h2>

  <div class="space-y-3">
    {skillGroups.map(group => (
      <div class="border border-gray-100 rounded-xl overflow-hidden">
        <button
          class="w-full px-5 py-4 flex items-center justify-between text-left hover:bg-gray-50 transition-colors"
          onclick={`toggleSection('${group.id}')`}
        >
          <span class="font-medium text-gray-800">{group.label}</span>
          <svg
            id={`${group.id}-arrow`}
            class="w-4 h-4 text-gray-400 transition-transform duration-300"
            fill="none" viewBox="0 0 24 24" stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>

        <div id={`${group.id}-content`} class="hidden px-5 pb-5 border-t border-gray-50">
          <div class="grid grid-cols-3 sm:grid-cols-5 gap-3 pt-4">
            {group.skills.map(icon => (
              <div class="flex flex-col items-center gap-2 p-3 rounded-lg hover:bg-gray-50 transition-colors group">
                <span class="opacity-80 group-hover:opacity-100 transition-opacity">
                  {icon === "html" && <HTML class="w-7 h-7" />}
                  {icon === "css" && <CSS class="w-7 h-7" />}
                  {icon === "javascript" && <JavaScript class="w-7 h-7" />}
                  {icon === "typescript" && <TypeScript class="w-7 h-7" />}
                  {icon === "react" && <React class="w-7 h-7" />}
                  {icon === "nextjs" && <NextJS class="w-7 h-7" />}
                  {icon === "astro" && <AstroIcon class="w-7 h-7" />}
                  {icon === "tailwind" && <Tailwind class="w-7 h-7" />}
                  {icon === "vue" && <Vue class="w-7 h-7" />}
                  {icon === "motion" && <Motion class="w-7 h-7" />}
                  {icon === "node" && <Node class="w-7 h-7" />}
                  {icon === "express" && <Express class="w-7 h-7 text-gray-800" />}
                  {icon === "php" && <Laravel class="w-7 h-7" />}
                  {icon === "python" && <Python class="w-7 h-7" />}
                  {icon === "supabase" && <Supa class="w-7 h-7" />}
                  {icon === "jwt" && <JWT class="w-7 h-7" />}
                  {icon === "stripe" && <Stripe class="w-7 h-7" />}
                  {icon === "java" && <Java class="w-7 h-7" />}
                  {icon === "kotlin" && <Kotlin class="w-7 h-7" />}
                  {icon === "expo" && <Expo class="w-7 h-7" />}
                  {icon === "mysql" && <MySQL class="w-7 h-7" />}
                  {icon === "firebase" && <Firebase class="w-7 h-7" />}
                  {icon === "mongo" && <Mongo class="w-7 h-7" />}
                  {icon === "git" && <Github class="w-7 h-7" />}
                  {icon === "cpanel" && <Cpanel class="w-7 h-7" />}
                  {icon === "vite" && <Vite class="w-7 h-7" />}
                  {icon === "todoist" && <Todoist class="w-7 h-7" />}
                  {icon === "slack" && <Slack class="w-7 h-7" />}
                  {icon === "vercel" && <Vercel class="w-7 h-7 text-gray-900" />}
                  {icon === "netlify" && <Netlify class="w-7 h-7" />}
                  {icon === "google" && <Google class="w-7 h-7" />}
                  {icon === "meta" && <Meta class="w-7 h-7" />}
                </span>
                <span class="text-xs text-gray-500 text-center leading-tight">
                  {icon === "html" && "HTML"}
                  {icon === "css" && "CSS"}
                  {icon === "javascript" && "JS"}
                  {icon === "typescript" && "TS"}
                  {icon === "react" && "React"}
                  {icon === "nextjs" && "Next.js"}
                  {icon === "astro" && "Astro"}
                  {icon === "tailwind" && "Tailwind"}
                  {icon === "vue" && "Vue.js"}
                  {icon === "motion" && "Motion"}
                  {icon === "node" && "Node.js"}
                  {icon === "express" && "Express"}
                  {icon === "php" && "Laravel"}
                  {icon === "python" && "Python"}
                  {icon === "supabase" && "Supabase"}
                  {icon === "jwt" && "JWT"}
                  {icon === "stripe" && "Stripe"}
                  {icon === "java" && "Java"}
                  {icon === "kotlin" && "Kotlin"}
                  {icon === "expo" && "Expo"}
                  {icon === "mysql" && "MySQL"}
                  {icon === "firebase" && "Firebase"}
                  {icon === "supabase" && "Supabase"}
                  {icon === "mongo" && "MongoDB"}
                  {icon === "git" && "Git"}
                  {icon === "cpanel" && "cPanel"}
                  {icon === "vite" && "Vite"}
                  {icon === "todoist" && "Todoist"}
                  {icon === "slack" && "Slack"}
                  {icon === "vercel" && "Vercel"}
                  {icon === "netlify" && "Netlify"}
                  {icon === "google" && "Analytics"}
                  {icon === "meta" && "Meta Pixel"}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script is:inline>
  let open = null;
  function toggleSection(id) {
    const content = document.getElementById(id + "-content");
    const arrow   = document.getElementById(id + "-arrow");
    if (!content) return;

    if (open && open !== id) {
      const oc = document.getElementById(open + "-content");
      const oa = document.getElementById(open + "-arrow");
      if (oc) { oc.classList.add("hidden"); }
      if (oa) { oa.style.transform = ""; }
    }

    const isHidden = content.classList.contains("hidden");
    content.classList.toggle("hidden", !isHidden);
    arrow.style.transform = isHidden ? "rotate(180deg)" : "";
    open = isHidden ? id : null;
  }
</script>
