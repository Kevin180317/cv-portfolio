---
const { URL } = Astro.props;
const isEn = URL === "/en/";

function getYearsSince(startYear: number): number {
  return new Date().getFullYear() - startYear;
}
const expYears = getYearsSince(2021);

const content = {
  greeting:  isEn ? "Hi, I'm Kevin." : "Hola, Soy Kevin.",
  role:      isEn ? "Full Stack Developer" : "Desarrollador Full Stack",
  location:  "Tijuana, México",
  email:     "okhuysen.dev@gmail.com",
  phone:     "+526632153454",
};

const socials = [
  { label: "Email",     href: `mailto:${content.email}`,                          icon: "mail"    },
  { label: "LinkedIn",  href: "https://linkedin.com/in/kevin-ortega-9abb6b235",   icon: "linkedin", target: "_blank" },
  { label: "GitHub",    href: "https://github.com/kevin180317",                   icon: "github",   target: "_blank" },
  { label: "Portfolio", href: "https://okhuysen.dev",                             icon: "globe",    target: "_blank" },
];
---

<section class="pt-6 pb-14 reveal">
  <!-- Label -->
  <p class="text-xs font-medium text-orange-500 tracking-widest uppercase mb-5">
    OKHUYSEN DEV · {content.location}
  </p>

  <!-- Name + role -->
  <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 leading-tight mb-2">
    {content.greeting}
  </h1>
  <p class="text-xl text-gray-500 font-light mb-1">
    {content.role}
  </p>
  <p class="text-sm text-orange-500 font-medium mb-8">
    +{expYears} {isEn ? "years of experience" : "años de experiencia"}
  </p>

  <!-- Availability -->
  <div class="flex items-center gap-2 mb-8">
    <span class="relative flex h-2.5 w-2.5">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
      <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-green-500"></span>
    </span>
    <span class="text-sm text-gray-600">
      {isEn ? "Available for new projects" : "Disponible para nuevos proyectos"}
    </span>
  </div>

  <!-- CTA buttons -->
  <div class="flex flex-wrap gap-3 mb-10">
    <a
      href="/#projects"
      class="inline-flex items-center gap-2 px-4 py-2 bg-gray-900 hover:bg-gray-700 text-white text-sm font-medium rounded-lg transition-colors"
    >
      {isEn ? "View Projects" : "Ver Proyectos"}
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
      </svg>
    </a>
    <a
      href="/cv.pdf"
      target="_blank"
      class="inline-flex items-center gap-2 px-4 py-2 border border-gray-200 hover:border-orange-400 text-gray-700 hover:text-orange-500 text-sm font-medium rounded-lg transition-all"
    >
      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
      </svg>
      {isEn ? "Download CV" : "Descargar CV"}
    </a>
  </div>

  <!-- Social links -->
  <div class="flex flex-wrap gap-3">
    {socials.map(s => (
      <a
        href={s.href}
        target={s.target ?? "_self"}
        rel={s.target === "_blank" ? "noopener noreferrer" : undefined}
        class="flex items-center gap-2 px-3 py-2 border border-gray-100 rounded-lg text-sm text-gray-500 hover:text-orange-500 hover:border-orange-200 transition-all"
      >
        {s.icon === "mail" && (
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        )}
        {s.icon === "linkedin" && (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.338 16.338H13.67V12.16c0-.995-.017-2.277-1.387-2.277-1.39 0-1.601 1.086-1.601 2.207v4.248H8.014v-8.59h2.559v1.174h.037c.356-.675 1.227-1.387 2.526-1.387 2.703 0 3.203 1.778 3.203 4.092v4.711zM5.005 6.575a1.548 1.548 0 11-.003-3.096 1.548 1.548 0 01.003 3.096zm-1.337 9.763H6.34v-8.59H3.667v8.59zM17.668 1H2.328C1.595 1 1 1.581 1 2.298v15.403C1 18.418 1.595 19 2.328 19h15.34c.734 0 1.332-.582 1.332-1.299V2.298C19 1.581 18.402 1 17.668 1z" clip-rule="evenodd"/>
          </svg>
        )}
        {s.icon === "github" && (
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 0C4.477 0 0 4.484 0 10.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0110 4.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.203 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0020 10.017C20 4.484 15.522 0 10 0z" clip-rule="evenodd"/>
          </svg>
        )}
        {s.icon === "globe" && (
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/>
          </svg>
        )}
        {s.label}
      </a>
    ))}
  </div>
</section>
