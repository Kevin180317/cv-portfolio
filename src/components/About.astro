---
const { URL } = Astro.props;

function getYearsSince(startYear: number): number {
  const now = new Date();
  const years = now.getFullYear() - startYear;
  const month = now.getMonth() + 1;
  return month >= 1 ? years : years - 1;
}

const expYears = getYearsSince(2021);
---

<section>
  <h2 class="text-2xl font-bold text-orange-600 mb-4">
    {URL === "/en/" ? "About Me" : "Sobre Mí"}
  </h2>

  <p class="text-lg text-gray-600 leading-relaxed text-start mb-4">
    {
      URL === "/en/"
        ? `+${expYears} years of professional experience as a Web and Mobile App Developer, with a specialized focus on digital solutions for the medical and dental sector. Based in Tijuana, Mexico.`
        : `+${expYears} años de experiencia profesional como Desarrollador Web y de Aplicaciones Móviles, con un enfoque especializado en soluciones digitales para el sector médico y dental. Radicado en Tijuana, México.`
    }
  </p>

  <p class="text-lg text-gray-600 leading-relaxed text-start mb-4">
    {
      URL === "/en/"
        ? "I work with frontend ecosystems using React, Astro and Next.js, as well as backend environments with Node.js and Express. Experience in databases and deployment of modern, scalable solutions."
        : "Manejo ecosistemas frontend con React, Astro y Next.js, así como entornos backend con Node.js y Express. Experiencia en bases de datos y despliegue de soluciones modernas y escalables."
    }
  </p>

  <p class="text-lg text-gray-600 leading-relaxed text-start mb-8">
    {
      URL === "/en/"
        ? "Passionate about creating fast, functional web experiences, with a focus on accessibility, performance, and good development practices."
        : "Apasionado por crear experiencias web rápidas y funcionales, con enfoque en accesibilidad, rendimiento y buenas prácticas de desarrollo."
    }
  </p>

  <h3 class="text-2xl font-bold text-orange-600 mb-4">
    {URL === "/en/" ? "Areas of Expertise" : "Áreas de Especialización"}
  </h3>

  <p class="text-gray-600 leading-relaxed mb-8">
    {
      URL === "/en/"
        ? "Web Development • Mobile Development • Frontend • Backend • CSS Frameworks • API Rest • Databases • SEO • Analytics • Version Control • Authentication • Credentials • Cpanel"
        : "Desarrollo Web • Desarrollo Móvil • Frontend • Backend • Frameworks CSS • API Rest • Bases de Datos • SEO • Analytics • Control de Versiones • Autenticación • Credenciales • Cpanel"
    }
  </p>
</section>
